{
  "name": "agent-wallet-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test --no-compile",
    "test:compile": "hardhat test",
    "deploy:polkadot": "hardhat run scripts/deploy.js --network polkadotTestnet",
    "deploy:moonbeam": "hardhat run scripts/deploy.js --network moonbaseAlpha",
    "deploy:all": "node scripts/deploy-all.js",
    "configure:hub": "node scripts/configure-hub.js",
    "test:deployed": "node scripts/test-deployed-flow.js",
    "export:artifacts": "hardhat run scripts/export-artifacts.js --network hardhatMainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@polkadot/api": "^16.5.4",
    "@polkadot/util-crypto": "^14.0.1",
    "dotenv": "^17.3.1",
    "hardhat": "^3.1.11",
    "solc": "^0.8.28"
  }
}
