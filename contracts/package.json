{
  "name": "agent-wallet-contracts",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test test/CrossChainDispatcher.js test/AgentSmartWallet.js --no-compile",
    "test:compile": "hardhat test test/CrossChainDispatcher.js test/AgentSmartWallet.js",
    "deploy:polkadot": "hardhat run scripts/deploy.js --network polkadotTestnet",
    "deploy:all": "node scripts/deploy-all.js",
    "test:deployed:xcm": "node scripts/test-deployed-xcm.js",
    "test:deployed:xcm:shibuya": "node scripts/test-deployed-xcm-shibuya.js",
    "export:artifacts": "hardhat run scripts/export-artifacts.js --network hardhatMainnet"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.3",
    "@polkadot-api/descriptors": "^0.0.1",
    "@polkadot/api": "^16.5.4",
    "@polkadot/util-crypto": "^14.0.1",
    "dotenv": "^17.3.1",
    "hardhat": "^3.1.11",
    "polkadot-api": "^1.23.3",
    "solc": "^0.8.28"
  }
}
